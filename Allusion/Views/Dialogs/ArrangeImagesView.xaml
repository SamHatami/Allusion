<Window
    x:Class="Allusion.Views.Dialogs.ArrangeImagesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="http://caliburnmicro.com"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Allusion.ViewModels.Dialogs"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Arrange Images"
    Width="360"
    Height="220"
    cm:Message.Attach="[Key Escape] = [Cancel]; [Key Enter] = [Apply]"
    d:DataContext="{d:DesignInstance Type=dialogs:ArrangeImagesViewModel}"
    ResizeMode="NoResize"
    Style="{DynamicResource DialogWindow}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}" />
    </WindowChrome.WindowChrome>

    <Grid Style="{DynamicResource DialogContentGrid}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Label
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Content="{Binding Title}"
            Style="{DynamicResource DialogTitleLabel}" />

        <Label
            Grid.Row="1"
            Content="Scope"
            Style="{DynamicResource DialogLabel}" />
        <ComboBox
            Grid.Row="2"
            ItemsSource="{Binding Scopes}"
            SelectedItem="{Binding SelectedScope}"
            Style="{DynamicResource DialogComboBox}" />

        <Label
            Grid.Row="3"
            Content="Scale"
            Style="{DynamicResource DialogLabel}" />
        <ComboBox
            Grid.Row="4"
            ItemsSource="{Binding ScaleModes}"
            SelectedItem="{Binding SelectedScaleMode}"
            Style="{DynamicResource DialogComboBox}" />

        <Label
            Grid.Row="5"
            Content="Margin"
            Style="{DynamicResource DialogLabel}" />
        <TextBox
            Grid.Row="6"
            VerticalAlignment="Top"
            Text="{Binding Margin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            Style="{DynamicResource DialogTextBox}" />

        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="Apply"
                Grid.Column="2"
                Content="Arrange"
                Style="{DynamicResource DialogPrimaryButton}" />
            <Button
                x:Name="Cancel"
                Grid.Column="3"
                Content="Cancel"
                Style="{DynamicResource DialogSecondaryButton}" />
        </Grid>
    </Grid>
</Window>
