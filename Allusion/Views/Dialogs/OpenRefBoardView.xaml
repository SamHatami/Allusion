<UserControl
    x:Class="Allusion.Views.Dialogs.OpenRefBoardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="http://caliburnmicro.com"
    xmlns:converters="clr-namespace:Allusion.WPFCore.Converter;assembly=Allusion.WPFCore"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dialogs="clr-namespace:Allusion.ViewModels.Dialogs"
    xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="600"
    cm:Message.Attach="[Key Escape] = [Cancel]; [Key Enter] = [Open]"
    d:DataContext="{d:DesignInstance Type=dialogs:OpenRefBoardViewModel}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:CountToBoolConverter x:Key="CountToBool" />
    </UserControl.Resources>

    <Border Style="{DynamicResource InfoBox}">
        <Grid Style="{DynamicResource DialogContentGrid}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="180" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Label
                Grid.Row="0"
                Content="Global Art Board Folder"
                Style="{DynamicResource DialogLabel}" />
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    Grid.Column="0"
                    Style="{DynamicResource DialogTextBox}"
                    Text="{Binding GlobalFolder}" />
                <Button
                    x:Name="BrowseGlobalFolder"
                    Grid.Column="1"
                    cm:Message.Attach="[BrowseGlobalFolder]"
                    Style="{DynamicResource DialogIconButton}">
                    <fa:IconImage Height="12" Icon="FolderOpen" />
                </Button>
            </Grid>

            <Label
                Grid.Row="2"
                Content="Art Boards"
                Style="{DynamicResource DialogLabel}" />
            <ListBox
                x:Name="RefBoards"
                Grid.Row="3"
                VerticalAlignment="Stretch"
                cm:Message.Attach="[Event MouseDoubleClick] = [Open]"
                ItemsSource="{Binding RefBoardPaths}"
                Loaded="OnViewLoaded"
                PreviewMouseRightButtonDown="OnRefBoardsPreviewMouseRightButtonDown"
                SelectedIndex="0"
                SelectedItem="{Binding SelectedRefBoard}"
                SelectionMode="Single"
                Style="{DynamicResource ListBox}">
                <ListBox.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem
                            cm:Message.Attach="[Rename]"
                            Header="Rename" />
                        <MenuItem
                            cm:Message.Attach="[OpenLocation]"
                            Header="Open location..." />
                        <Separator />
                        <MenuItem
                            cm:Message.Attach="[Remove]"
                            Header="Remove" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Label
                            Content="{Binding Name}"
                            Style="{DynamicResource DialogLabel}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="New"
                    Grid.Column="0"
                    Content="New"
                    Style="{DynamicResource DialogSecondaryButton}" />
                <Button
                    x:Name="Open"
                    Grid.Column="2"
                    Content="Open"
                    IsEnabled="{Binding RefBoardPaths, Converter={StaticResource CountToBool}}"
                    Style="{DynamicResource DialogPrimaryButton}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
