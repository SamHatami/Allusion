<Window
    x:Class="Allusion.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cm="http://caliburnmicro.com"
    xmlns:converters="clr-namespace:Allusion.WPFCore.Converter;assembly=Allusion.WPFCore"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="clr-namespace:Allusion.ViewModels"
    Title="MainView"
    Width="1024"
    Height="1024"
    cm:Message.Attach="[Gesture Ctrl+V] = [PasteOnCanvas];[Gesture Ctrl+S] = [Save];[Gesture Ctrl+O] = [OpenRefBoardDialog];[Gesture Ctrl+N] = [NewRefBoardDialog];[Key Delete] = [Remove]; [Gesture F1] = [ShowHelp]"
    d:DataContext="{d:DesignInstance Type=viewModels:MainViewModel}"
    DragEnter="MainView_OnDragEnter"
    DragLeave="MainView_OnDragLeave"
    Initialized="OnWindowInitialized"
    StateChanged="WindowStateChangedHandler"
    Topmost="{Binding Configuration.TopMost, Mode=TwoWay,NotifyOnSourceUpdated=True}"
    mc:Ignorable="d">
    <Window.Resources>
        <converters:InvertBoolToVis x:Key="InvertBoolVis" />
        <converters:CountToBoolConverter x:Key="CountToBool" />
    </Window.Resources>

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}" />
    </WindowChrome.WindowChrome>

    <Grid Background="{DynamicResource Board.Background}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <!--  TITLE BAR ROW  -->
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Style="{DynamicResource WindowTitleBar}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <DockPanel
                    Grid.Column="0"
                    Margin="10,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        DockPanel.Dock="Top"
                        FontFamily="Arial Black"
                        FontSize="14"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Allusion.Logo}">
                        ALLUSION
                        <TextBlock.Effect>
                            <DropShadowEffect
                                BlurRadius="2"
                                Opacity="1"
                                ShadowDepth="0"
                                Color="{DynamicResource Logo.Border}" />
                        </TextBlock.Effect>
                    </TextBlock>
                </DockPanel>

                <Label
                    Grid.Column="0"
                    Grid.ColumnSpan="7"
                    Margin="4,0,0,0"
                    Content="{Binding RefBoardViewModel.BoardName}"
                    Style="{DynamicResource TitleBarLabel}" />


                <Button
                    x:Name="ShowHelp"
                    Grid.Column="1"
                    RenderOptions.EdgeMode="Aliased"
                    Style="{DynamicResource TitleBarButtonStyle}"
                    ToolTip="Help!!">
                    <fa:IconImage Width="16" Icon="QuestionCircle" />
                </Button>
                <Button
                    x:Name="SetTopMost"
                    Grid.Column="2"
                    Click="Settings_Click"
                    RenderOptions.EdgeMode="Aliased"
                    Style="{DynamicResource TitleBarButtonStyle}"
                    ToolTip="Turn on/off always on top">
                    <fa:IconImage
                        x:Name="DisplayIcon"
                        Width="16"
                        Icon="Display" />
                </Button>

                <Button
                    Grid.Column="3"
                    Click="ThemeSwitch_Click"
                    RenderOptions.EdgeMode="Aliased"
                    Style="{DynamicResource TitleBarButtonStyle}"
                    ToolTip="Switch theme">
                    <fa:IconImage Width="16" Icon="CircleHalfStroke" />
                </Button>
                <Button
                    Grid.Column="4"
                    Click="OnMinimizeButtonClick"
                    RenderOptions.EdgeMode="Aliased"
                    Style="{DynamicResource TitleBarButtonStyle}">
                    <fa:IconImage Width="12" Icon="WindowMinimize" />
                </Button>
                <Button
                    Name="RestoreButton"
                    Grid.Column="5"
                    Click="OnMaximizeRestoreButtonClick"
                    Style="{DynamicResource TitleBarButtonStyle}">
                    <fa:IconImage Height="12" Icon="compress" />
                </Button>
                <Button
                    Name="MaximizeButton"
                    Grid.Column="6"
                    Click="OnMaximizeRestoreButtonClick"
                    Style="{DynamicResource TitleBarButtonStyle}">
                    <fa:IconImage Height="12" Icon="expand" />
                </Button>
                <Button
                    Grid.Column="7"
                    Click="OnCloseButtonClick"
                    Style="{DynamicResource TitleBarButtonClose}">
                    <fa:IconImage Height="12" Icon="Close" />
                </Button>
            </Grid>
        </Border>
        <ContentControl Grid.Row="1" cm:View.Model="{Binding RefBoardViewModel}" />

        <Grid
            Grid.Row="1"
            VerticalAlignment="Center"
            DataContext="{Binding StartBoardPicker}"
            Visibility="{Binding DataContext.RefBoardViewModel, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertBoolVis}, ConverterParameter=Normal}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <DockPanel
                Grid.Row="0"
                Margin="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <TextBlock
                    HorizontalAlignment="Center"
                    DockPanel.Dock="Top"
                    FontFamily="Arial Black"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Allusion.Logo}">
                    <Run FontSize="48" Text="A" /><Run FontSize="36" Text="LLUSIO" /><Run FontSize="36" Text="N" />

                    <TextBlock.Effect>
                        <DropShadowEffect
                            BlurRadius="2"
                            Opacity="1"
                            ShadowDepth="0"
                            Color="{DynamicResource Logo.Border}" />
                    </TextBlock.Effect>
                </TextBlock>
            </DockPanel>

            <Border
                Grid.Row="1"
                Width="600"
                Style="{DynamicResource InfoBox}">
                <Grid Style="{DynamicResource DialogContentGrid}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="180" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Label
                        Grid.Row="0"
                        Content="Global Art Board Folder"
                        Style="{DynamicResource DialogLabel}" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            Style="{DynamicResource DialogTextBox}"
                            Text="{Binding GlobalFolder}" />
                        <Button
                            x:Name="BrowseGlobalFolder"
                            Grid.Column="1"
                            cm:Message.Attach="[BrowseGlobalFolder]"
                            Style="{DynamicResource DialogIconButton}">
                            <fa:IconImage Height="12" Icon="FolderOpen" />
                        </Button>
                    </Grid>

                    <Label
                        Grid.Row="2"
                        Content="New Board"
                        Style="{DynamicResource DialogLabel}" />
                    <TextBox
                        Grid.Row="3"
                        Style="{DynamicResource DialogTextBox}"
                        Text="{Binding NewBoardName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <Label
                        Grid.Row="4"
                        Content="Art Boards"
                        Style="{DynamicResource DialogLabel}" />
                    <ListBox
                        x:Name="RefBoards"
                        Grid.Row="5"
                        ItemsSource="{Binding RefBoardPaths}"
                        SelectedIndex="0"
                        SelectedItem="{Binding SelectedRefBoard}"
                        SelectionMode="Single"
                        cm:Message.Attach="[Event MouseDoubleClick] = [Open]"
                        Style="{DynamicResource ListBox}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Label
                                    Content="{Binding Name}"
                                    Style="{DynamicResource DialogLabel}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Grid.Row="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <Button
                            x:Name="New"
                            Grid.Column="0"
                            Content="New"
                            Style="{DynamicResource DialogSecondaryButton}" />
                        <Button
                            x:Name="Open"
                            Grid.Column="2"
                            Content="Open"
                            IsEnabled="{Binding RefBoardPaths, Converter={StaticResource CountToBool}}"
                            Style="{DynamicResource DialogPrimaryButton}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <ContentControl
            Grid.Row="1"
            Width="150"
            Margin="0,20"
            VerticalAlignment="Bottom"
            cm:View.Model="{Binding Notification}" />

    </Grid>
</Window>
