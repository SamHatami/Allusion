<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="InfoBox" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Info.BackGround}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Allusion.Logo.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{DynamicResource DefaultCornerRadius}" />
    </Style>
</ResourceDictionary>
